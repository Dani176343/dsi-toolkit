{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSI Toolkit",
  "version": "0.1.0",
  "identifier": "pt.cma.dsitoolkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DSI Toolkit",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    },
    "publisher": "Câmara Municipal de Abrantes",
    "copyright": "© 2025 Câmara Municipal de Abrantes"
  }
}
